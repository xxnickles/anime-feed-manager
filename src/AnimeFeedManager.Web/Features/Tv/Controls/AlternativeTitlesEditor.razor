@using System.Text.Json
@implements IRenderableComponent<AlternativeTitlesViewModel>

@if (Model is not null)
{
    var titles = Model.AlternativeTitles ?? [];
    var hasTitles = titles.Length > 0;

    <EditForm Model="@Model"
              hx-post="tv/alternative-title"
              hx-swap="outerHTML"
              hx-indicator="@_loaderSelector"
              hx-confirm="@($"Do you want update '{Model.SeriesTitle}' alternative titles?")"
              data-items='@JsonSerializer.Serialize(titles)'
              data-field-name="@nameof(Model.AlternativeTitles)"
              class="modal-box"
              _="@Script">

        <input type="hidden" name="@nameof(Model.SeriesTitle)" value="@Model.SeriesTitle"/>
        <input type="hidden" name="@nameof(Model.SeriesId)" value="@Model.SeriesId"/>
        <input type="hidden" name="@nameof(Model.Season)" value="@Model.Season"/>

        <div class="join w-full my-3">
            <div class="w-full">
                <label class="input join-item w-full">
                    <input type="text" class="w-full" placeholder="Alternative Title"
                           data-title-input
                           _="on keydown[key=='Enter']
                                halt the event's default
                                send addTitle to (the closest <form/>)"/>
                </label>
            </div>
            <button type="button" class="btn btn-neutral join-item"
                    _="on click send addTitle to (the closest <form/>)">Add</button>
        </div>

        <div class="alert alert-warning my-2 alt-titles-dirty-banner" hidden>
            <span>You have unsaved changes.</span>
            <span id="@_loaderId" class="loading loading-spinner loading-sm ml-2 htmx-indicator" aria-label="Saving"></span>
        </div>

        <ul class="list bg-base-100 shadow-md alt-titles-list">
            <li class="alt-titles-empty p-4 pb-2 text-warning tracking-wide" hidden="@hasTitles">No alternative titles</li>
            @for (int idx = 0; idx < titles.Length; idx++)
            {
                var title = titles[idx];
                <li class="list-row items-center">
                    <div class="text-4xl font-thin opacity-30 tabular-nums min-w-12 text-center" data-row-index>
                        @((idx + 1).ToString("D2"))
                    </div>
                    <div class="list-col-grow">
                        <div data-row-title>@title</div>
                    </div>
                    <input type="hidden" data-alt-title-hidden
                           name="@(nameof(Model.AlternativeTitles))[@idx]"
                           value="@title"/>
                    <button type="button" class="btn btn-square btn-ghost btn-error"
                            aria-label="Remove title"
                            _="on click send removeTitle(row: me.closest('li')) to (the closest <form/>)">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                             stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                        </svg>
                    </button>
                </li>
            }
        </ul>

        <template data-row-blueprint>
            <li class="list-row items-center">
                <div class="text-4xl font-thin opacity-30 tabular-nums min-w-12 text-center" data-row-index></div>
                <div class="list-col-grow">
                    <div data-row-title></div>
                </div>
                <input type="hidden" data-alt-title-hidden/>
                <button type="button" class="btn btn-square btn-ghost btn-error"
                        aria-label="Remove title"
                        _="on click send removeTitle(row: me.closest('li')) to (the closest <form/>)">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                         stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                    </svg>
                </button>
            </li>
        </template>

        <div class="mt-4 flex gap-2 justify-end">
            <button type="button" class="btn"
                    _="on click call (the closest <dialog/>).close()">Close</button>
            <input type="submit" class="btn btn-primary alt-titles-submit" value="Save and close" hidden/>
        </div>
    </EditForm>
}

@code {
    [Parameter, EditorRequired] public AlternativeTitlesViewModel? Model { get; set; }
    private string _loaderId = string.Empty;
    private string _loaderSelector = string.Empty;

    protected override void OnInitialized()
    {
        _loaderId = IdHelpers.GetUniqueName("alt-titles-loader");
        _loaderSelector = $"#{_loaderId}";
    }

    public static RenderFragment AsRenderFragment(AlternativeTitlesViewModel viewModel) => builder =>
    {
        builder.OpenComponent<AlternativeTitlesEditor>(0);
        builder.AddAttribute(1, nameof(Model), viewModel);
        builder.CloseComponent();
    };
}
