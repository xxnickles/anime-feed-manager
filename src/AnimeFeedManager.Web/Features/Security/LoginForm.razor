@using AnimeFeedManager.Shared.Results
@inject IConfiguration Configuration
@inject IWebHostEnvironment Env

@* The submit is intercepted by the hyperscript (LoginForm.razor.hs): it runs the passkey sign-in,
   verifies the token, fills the hidden Id, then sends `loginComplete` — which is the form's only
   htmx trigger, so the POST to /login carries the resolved user id. *@
<form id="login-form"
      hx-post="/login"
      hx-swap="outerHTML"
      hx-trigger="loginComplete"
      data-passkey-api-key="@ApiKey"
      data-passkey-module="@ModuleUrl"
      class="card-body"
      _="@Script">
    <AntiforgeryToken />

    <fieldset class="form-control">
        <label class="floating-label" for="email-input">
            <input id="email-input" data-passkey-alias-input required type="email"
                   placeholder="Enter your email" class="input input-bordered w-full" />
            <span class="label-text">Email</span>
        </label>
        <div data-passkey-inline-error hidden class="label">
            <span class="label-text-alt text-error">Please check your email and try again</span>
        </div>
    </fieldset>

    <input type="hidden" name="Id" data-passkey-user-id value="@Model.Id" />
    <input type="hidden" name="Alias" data-passkey-alias value="@Model.Alias" />
    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

    <fieldset class="form-control mt-6">
        <button type="submit" class="btn btn-primary" data-passkey-submit>
            <span data-passkey-submit-spinner hidden class="loading loading-spinner loading-sm"></span>
            <span data-passkey-submit-label>Login</span>
        </button>
    </fieldset>

    <div data-passkey-error hidden class="alert alert-error mt-4" role="alert">
        <span data-passkey-error-message></span>
    </div>

    <div data-passkey-unauthorized hidden class="alert alert-warning mt-4" role="alert">
        <div>
            <p>Your account is not registered.</p>
            <a class="link link-primary font-semibold" href="/register">Register here</a>
        </div>
    </div>

    @if (HasError)
    {
        <div class="alert alert-error mt-4" role="alert">
            <span>@ErrorMessage</span>
        </div>
    }
</form>

@code {
    [Parameter] public LoginViewModel Model { get; set; } = new();
    [Parameter] public DomainError? Error { get; set; }

    private bool HasError => Error is not null;

    private string ApiKey => Configuration["Passwordless:ApiKey"] ?? string.Empty;

    private string ModuleUrl => Env.IsDevelopment()
        ? "/lib/passwordless-client/dist/esm/passwordless.mjs"
        : "/lib/passwordless-client/dist/esm/passwordless.min.mjs";

    private string ErrorMessage => Error switch
    {
        DomainValidationErrors validation => string.Join(", ", validation.Errors.SelectMany(e => e.Errors)),
        not null => Error.Message,
        _ => "Login failed. Please try again."
    };
}
