@using AnimeFeedManager.Shared.Results
@inject IConfiguration Configuration
@inject IWebHostEnvironment Env

@if (Model.Token is not null)
{
    @* Token issued — the browser creates the passkey credential against Passwordless. The hyperscript
       (RegistrationForm.razor.hs) lazily imports the ESM client using the data-attrs below. *@
    <div id="registration-form"
         class="card-body"
         data-passkey-token="@Model.Token"
         data-passkey-api-key="@ApiKey"
         data-passkey-module="@ModuleUrl"
         _="@Script">

        <div data-passkey-loading class="flex flex-col items-center gap-4">
            <span class="loading loading-spinner loading-lg text-primary"></span>
            <p class="text-center">Setting up your passkey…</p>
        </div>

        <div data-passkey-success hidden class="flex flex-col items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-success h-16 w-16" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-center text-lg font-semibold">Account created successfully!</p>
            <a class="btn btn-primary" href="/login">Login now</a>
        </div>

        <div data-passkey-error hidden class="flex flex-col items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-error h-16 w-16" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p data-passkey-error-message class="text-center text-error"></p>
            <a class="btn btn-outline" href="/register">Try again</a>
        </div>
    </div>
}
else
{
    <form id="registration-form"
          hx-post="/create-token"
          hx-swap="outerHTML"
          class="card-body">
        <AntiforgeryToken />

        <fieldset class="form-control">
            <label class="floating-label" for="email-input">
                <input id="email-input" name="Email" type="email" required value="@Model.Email"
                       placeholder="Enter your email"
                       class="@($"input input-bordered w-full {(HasError ? "input-error" : "")}")" />
                <span class="label-text">Email</span>
            </label>
        </fieldset>

        <fieldset class="form-control mt-4">
            <label class="floating-label" for="display-name-input">
                <input id="display-name-input" name="DisplayName" required minlength="2" value="@Model.DisplayName"
                       placeholder="Enter your display name"
                       class="@($"input input-bordered w-full {(HasError ? "input-error" : "")}")" />
                <span class="label-text">Display Name</span>
            </label>
        </fieldset>

        <fieldset class="form-control mt-6">
            <button type="submit" class="btn btn-primary">Register</button>
        </fieldset>

        @if (HasError)
        {
            <div class="alert alert-error mt-4" role="alert">
                <span>@ErrorMessage</span>
            </div>
        }

        <div class="text-center mt-4">
            <span class="text-sm">Already have an account? </span>
            <a class="link link-primary text-sm font-semibold" href="/login">Login</a>
        </div>
    </form>
}

@code {
    [Parameter] public RegisterViewModel Model { get; set; } = new();
    [Parameter] public DomainError? Error { get; set; }

private bool HasError => Error is not null;

    private string ApiKey => Configuration["Passwordless:ApiKey"] ?? string.Empty;

    private string ModuleUrl => Env.IsDevelopment()
        ? "/lib/passwordless-client/dist/esm/passwordless.mjs"
        : "/lib/passwordless-client/dist/esm/passwordless.min.mjs";

    private string ErrorMessage => Error switch
    {
        DomainValidationErrors validation => string.Join(", ", validation.Errors.SelectMany(e => e.Errors)),
        not null => Error.Message,
        _ => "Registration failed. Please try again."
    };
}
