@page "/add-credential/{UserId}"
@using AnimeFeedManager.Web.Features.Security

<AppPageTitle Title="Add Passkey" />

<section class="mx-auto flex w-full max-w-sm flex-col items-center gap-6 pt-8">
    <img src="/images/logo.svg" alt="Anime Feed Manager" class="h-16 w-auto" />
    <p class="text-center text-base-content/70">Add another passkey to your account</p>
    <article class="card w-full bg-base-100 shadow-xl">
        <AddCredentialForm Model="new AddCredentialsViewModel { Id = UserId }" />
    </article>
</section>

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;
}
