@using AnimeFeedManager.Shared.Results
@inject IConfiguration Configuration
@inject IWebHostEnvironment Env

@if (Model.Token is not null)
{
    <div id="add-credential-form"
         class="card-body"
         data-passkey-token="@Model.Token"
         data-passkey-api-key="@ApiKey"
         data-passkey-module="@ModuleUrl"
         _="@Script">

        <div data-passkey-loading class="flex flex-col items-center gap-4">
            <span class="loading loading-spinner loading-lg text-primary"></span>
            <p class="text-center">Setting up your passkey…</p>
        </div>

        <div data-passkey-success hidden class="flex flex-col items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-success h-16 w-16" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-center text-lg font-semibold">Passkey added successfully!</p>
            <a class="btn btn-primary" href="/login">Login now</a>
        </div>

        <div data-passkey-error hidden class="flex flex-col items-center gap-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="stroke-error h-16 w-16" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p data-passkey-error-message class="text-center text-error"></p>
            <button type="button" class="btn btn-outline" data-passkey-retry-reload>Try again</button>
        </div>
    </div>
}
else
{
    <form id="add-credential-form"
          hx-post="/add-credential"
          hx-swap="outerHTML"
          class="card-body">
        <AntiforgeryToken />

        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="text-center mb-4">
            <p class="text-sm text-base-content/70">Add a new passkey to your account</p>
        </div>

        <fieldset class="form-control mt-6">
            <button type="submit" class="btn btn-primary">Add Passkey</button>
        </fieldset>

        @if (HasError)
        {
            <div class="alert alert-error mt-4" role="alert">
                <span>@ErrorMessage</span>
            </div>
        }

        <div class="text-center mt-4">
            <a class="link link-primary text-sm font-semibold" href="/login">Skip and login</a>
        </div>
    </form>
}

@code {
    [Parameter] public AddCredentialsViewModel Model { get; set; } = new();
    [Parameter] public DomainError? Error { get; set; }

    private bool HasError => Error is not null;

    private string ApiKey => Configuration["Passwordless:ApiKey"] ?? string.Empty;

    private string ModuleUrl => Env.IsDevelopment()
        ? "/lib/passwordless-client/dist/esm/passwordless.mjs"
        : "/lib/passwordless-client/dist/esm/passwordless.min.mjs";

    private string ErrorMessage => Error switch
    {
        DomainValidationErrors validation => string.Join(", ", validation.Errors.SelectMany(e => e.Errors)),
        not null => Error.Message,
        _ => "Failed to add credential. Please try again."
    };
}
