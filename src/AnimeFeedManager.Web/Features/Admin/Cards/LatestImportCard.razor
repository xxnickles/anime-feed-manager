@using Microsoft.AspNetCore.Components.Forms

@* Latest-season import trigger. No data to send, but we still post a <form> so the
   antiforgery token rides along (the Noop construct). htmx posts to the admin
   library-import endpoint, which fires the import (JobExecutor, single-flight
   "library-import" gate) and returns an out-of-band toast as feedback. hx-swap="none"
   leaves this card untouched; transition:false keeps the toast response out of the
   view transition. *@

<div class="flex h-full flex-col gap-3 rounded-2xl border-2 border-base-content bg-base-100 p-5 shadow-brutal">
    <div class="flex flex-col gap-1">
        <h3 class="font-display text-base font-black tracking-[-0.02em] text-base-content">
            Latest Season
        </h3>
        <p class="text-sm text-base-content/70">
            Import the current season's TV anime from Jikan.
        </p>
    </div>

    <form hx-post="/admin/library/import/latest"
          hx-swap="none transition:false"
          hx-confirm="Import the latest season now?"
          class="mt-auto">
        <AntiforgeryToken />
        <button type="submit" class="btn btn-primary gap-2">
            Import latest season
            <span class="htmx-indicator loading loading-spinner loading-sm"></span>
        </button>
    </form>
</div>
