@page "/admin"
@using AnimeFeedManager.Web.Features.Admin.Cards

@* Admin dashboard — hosts the controls for keeping the season library in sync
   (manual import, status refresh, …) and, later, library stats / charts. Layout
   follows the dashboard grid in .claude/references/nexus-dashboard-grid.md, hardened
   to the brutalist theme: the responsive grid is the durable bit; trigger cards (and
   future widgets) mount into it. Page padding comes from MainLayout's #main-content. *@

<AppPageTitle Title="Admin" />

<div class="flex flex-col gap-10 py-2">

    @* Page header *@
    <header class="flex flex-col gap-2">
        <p class="font-display text-xs font-semibold uppercase tracking-widest text-base-content/50">
            Admin
        </p>
        <h1 class="font-display text-3xl font-black tracking-[-0.03em] text-base-content">
            Season Controls
        </h1>
        <p class="max-w-2xl text-base-content/70">
            Manage the season library — trigger imports, refresh status and keep the
            catalogue in sync.
        </p>
    </header>

    @* Section: library import + season-data controls *@
    <section class="flex flex-col gap-4">
        <div class="flex items-center justify-between gap-3">
            <h2 class="font-display text-lg font-black tracking-[-0.02em] text-base-content">
                Season Library
            </h2>
        </div>

        @* Dashboard grid — trigger cards now, stats / charts later. *@
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3">
            <LatestImportCard />
            @* TODO[next]: custom-season import trigger card *@
        </div>
    </section>

</div>
