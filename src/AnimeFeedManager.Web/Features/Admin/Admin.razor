@page "/admin"

@* Admin section landing — hosts the controls for keeping the season library in
   sync (manual import, status refresh, …). Placeholder shell for now; the action
   cards land as each control is wired up in later items. *@

<AppPageTitle Title="Admin" />

<section class="mx-auto flex max-w-3xl flex-col gap-6 py-10">
    <header class="flex flex-col gap-2">
        <p class="font-display text-xs font-semibold uppercase tracking-widest text-base-content/50">
            Admin
        </p>
        <h1 class="font-display text-3xl font-black tracking-[-0.03em] text-base-content">
            Season Controls
        </h1>
        <p class="text-base-content/70">
            Manage the season library — trigger imports, refresh status and keep the
            catalogue in sync. Controls arrive as each one is wired up.
        </p>
    </header>

    <div class="rounded-2xl border-2 border-base-content bg-base-100 p-5 text-sm text-base-content/70 shadow-brutal">
        No controls wired yet — this is the admin shell.
    </div>
</section>
