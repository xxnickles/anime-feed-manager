@* Mobile navigation menu — a full-screen overlay (mobile-only, md:hidden).
   Toggled by the #mobile-drawer checkbox in MainLayout, which is a `peer` sibling:
   `peer-checked:` drives this panel's open state. The topbar hamburger and this
   panel's close button are <label for="mobile-drawer"> controls.

   It covers the whole viewport with a tinted, blurred backdrop so a boosted
   navigation's #main-content swap happens hidden behind it; MainLayout's
   `on htmx:after:swap` handler then unchecks the toggle and the menu fades out
   (opacity + visibility, allow-discrete) to reveal the freshly-swapped page — no
   old-content flash, and nothing to coordinate with the content view transition.

   Layout structure only — the seasons list and account / sign-out sections are
   deferred (slot marked below; they need data + auth). *@

<div class="fixed inset-0 z-[100] flex flex-col bg-base-100/85 backdrop-blur-xl md:hidden
            [view-transition-name:mobile-menu]
            invisible opacity-0 transition-[opacity,visibility] transition-discrete duration-200 ease-out
            peer-checked:visible peer-checked:opacity-100"
     aria-label="Main menu"
     _="on keyup[key is 'Escape'] from the document set #mobile-drawer's checked to false">

    @* Head: brand + close *@
    <div class="flex items-center justify-between border-b-[3px] border-base-content px-4 py-3.5">
        <span class="inline-flex items-center gap-2 font-display text-[1.05rem] font-black tracking-[-0.03em] text-base-content">
            <img src="/images/logo.svg" alt="" aria-hidden="true" class="h-[2.1rem] w-[2.1rem]" />
            <span>amf</span>
        </span>
        <label for="mobile-drawer"
               aria-label="Close menu"
               class="inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-lg text-base-content/75 transition-colors hover:bg-base-content/10 hover:text-base-content">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M18 6L6 18M6 6l12 12" />
            </svg>
        </label>
    </div>

    @* Scrollable body: browse links + recent seasons share one scroll region so the browse nav
       doesn't fill the height and push the seasons off-screen. *@
    <div class="flex flex-1 flex-col overflow-y-auto">
    <nav class="flex flex-col gap-1 px-4 py-5" aria-label="Browse">
        <NavLink href="/seasons"
                 ActiveClass="bg-base-content/10 text-base-content"
                 class="flex items-center gap-3 rounded-lg px-3 py-3 text-base font-medium text-base-content/80 transition-colors hover:bg-base-content/10 hover:text-base-content">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="5" width="18" height="16" rx="2" />
                <path d="M8 3v4M16 3v4M3 11h18" />
            </svg>
            All seasons
        </NavLink>
        <NavLink href="/admin"
                 ActiveClass="bg-base-content/10 text-base-content"
                 class="flex items-center gap-3 rounded-lg px-3 py-3 text-base font-medium text-base-content/80 transition-colors hover:bg-base-content/10 hover:text-base-content">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="3" />
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
            </svg>
            Admin
        </NavLink>
    </nav>

    @* Recent seasons — same RecentSeasons provider as the topbar pills; the dot marks the airing
       season (IsCurrent), the highlight marks the active route (NavLink). *@
    <RecentSeasons Context="recent">
        @{ var landing = SeasonNav.Current(recent); }
        <div class="border-t border-base-content/[0.06] px-4 py-4">
            <div class="px-1.5 pb-2 font-display text-[0.62rem] font-bold uppercase tracking-[0.14em] text-base-content/50">Recent seasons</div>
            <div class="flex flex-col gap-0.5">
                @foreach (var entry in recent)
                {
                    var isLanding = entry.SeriesSeason == landing?.SeriesSeason;
                    <NavLink href="@(isLanding ? "/" : $"/{entry.SeriesSeason}")"
                             Match="@(isLanding ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                             ActiveClass="bg-primary/[0.12]"
                             class="flex items-center gap-3 rounded-lg px-2 py-2.5 text-base-content transition-colors hover:bg-base-content/[0.07]">
                        <span class="w-10 font-mono text-[0.66rem] uppercase tracking-[0.06em] text-base-content/50">@entry.SeriesSeason.Year</span>
                        <span class="font-display text-[0.95rem] font-bold">@SeasonLabel(entry.SeriesSeason.Season.ToString())</span>
                        @if (entry.IsCurrent)
                        {
                            <span class="ml-auto h-2 w-2 rounded-full bg-success" title="Now airing"></span>
                        }
                    </NavLink>
                }
            </div>
        </div>
    </RecentSeasons>
    </div>

    @* TODO[deferred]: account / sign-out — needs auth *@
</div>

@code {
    private static string SeasonLabel(string season) =>
        season.Length == 0 ? season : char.ToUpperInvariant(season[0]) + season[1..];
}
