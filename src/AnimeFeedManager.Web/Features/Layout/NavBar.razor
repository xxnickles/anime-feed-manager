@using AnimeFeedManager.Web.Features.Security
@* App topbar — sticky, glassy chrome shown on every page. The recent-season pills come from the
   RecentSeasons provider; the all-seasons link points at /seasons. The admin link is admin-only;
   the login/logout affordance reflects auth state. The hamburger toggles MobileDrawer's checkbox. *@

<header id="topbar"
        hx-swap-oob="@(OutOfBand ? "outerMorph transition:false" : null)"
        class="sticky top-0 z-40 border-b-[3px] border-base-content bg-base-100">
    <div class="flex max-w-[100vw] items-center gap-2.5 px-4 py-2.5 md:gap-3 md:px-7">

        @* Mobile menu trigger *@
        <label for="mobile-drawer"
               aria-label="Open menu"
               class="inline-flex h-8 w-8 cursor-pointer items-center justify-center rounded-lg text-base-content/75 transition-colors hover:bg-base-content/10 hover:text-base-content md:hidden">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 12h18M3 6h18M3 18h18" />
            </svg>
        </label>

        @* Brand mark — the mascot SVG renders in its own colours (no mask/tint). *@
        <NavLink href="/" Match="NavLinkMatch.All" title="AMF — Anime Feed Manager"
                 class="inline-flex items-center gap-2 py-0.5 font-display text-[1.05rem] font-black tracking-[-0.03em] text-base-content">
            <img src="/images/logo.svg" alt="" aria-hidden="true" class="h-[2.1rem] w-[2.1rem]" />
            <span class="hidden sm:inline">amf <span class="font-normal opacity-50">/</span> <span class="opacity-70">anime feed</span></span>
        </NavLink>

        <RecentSeasons Context="recent">
            @{ var landing = SeasonNav.Current(recent); }
            <nav class="ml-4 hidden items-end gap-1 md:flex" aria-label="Recent seasons">
                @* Render oldest -> newest so the current season sits on the right. *@
                @foreach (var entry in recent.Reverse())
                {
                    var isLanding = entry.SeriesSeason == landing?.SeriesSeason;
                    <NavLink href="@(isLanding ? "/" : $"/{entry.SeriesSeason}")"
                             Match="@(isLanding ? NavLinkMatch.All : NavLinkMatch.Prefix)"
                             ActiveClass="!bg-primary !text-primary-content"
                             class="relative rounded-md px-2.5 py-1.5 text-center font-display text-[0.78rem] font-semibold uppercase tracking-[0.08em] text-base-content/65 transition-colors hover:bg-base-content/[0.06] hover:text-base-content">
                        <span class="block text-[0.6rem] font-medium tracking-[0.15em] opacity-70">@entry.SeriesSeason.Year</span>
                        @entry.SeriesSeason.Season
                        @if (entry.IsCurrent)
                        {
                            <span class="absolute right-1 top-1 h-1.5 w-1.5 rounded-full bg-success" title="Now airing"></span>
                        }
                    </NavLink>
                }
            </nav>
        </RecentSeasons>

        <div class="ml-auto flex items-center gap-0.5">
            @* TODO[deferred]: hub-status pill (needs hub) · watchlist / notifications icons (need routes) *@
            <NavLink href="/seasons"
                     title="All seasons"
                     aria-label="All seasons"
                     ActiveClass="bg-base-content/10 text-base-content"
                     class="inline-flex h-8 items-center gap-2 rounded-lg px-2.5 text-sm font-medium text-base-content/75 transition-colors hover:bg-base-content/10 hover:text-base-content">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="16" rx="2" />
                    <path d="M8 3v4M16 3v4M3 11h18" />
                </svg>
                <span class="hidden lg:inline">Seasons</span>
            </NavLink>
            <AuthorizeView Policy="@Policies.AdminRequired">
                <NavLink href="/admin"
                         title="Admin"
                         aria-label="Admin"
                         ActiveClass="bg-base-content/10 text-base-content"
                         class="inline-flex h-8 items-center gap-2 rounded-lg px-2.5 text-sm font-medium text-base-content/75 transition-colors hover:bg-base-content/10 hover:text-base-content">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="12" cy="12" r="3" />
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                    </svg>
                    <span class="hidden lg:inline">Admin</span>
                </NavLink>
            </AuthorizeView>
            <AuthorizeView>
                <Authorized>
                    <NavLink href="/logout"
                             title="Logout"
                             aria-label="Logout"
                             class="inline-flex h-8 items-center gap-2 rounded-lg px-2.5 text-sm font-medium text-base-content/75 transition-colors hover:bg-base-content/10 hover:text-base-content">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" />
                        </svg>
                        <span class="hidden lg:inline">Logout</span>
                    </NavLink>
                </Authorized>
                <NotAuthorized>
                    <NavLink href="/login"
                             title="Login"
                             aria-label="Login"
                             ActiveClass="bg-base-content/10 text-base-content"
                             class="inline-flex h-8 items-center gap-2 rounded-lg px-2.5 text-sm font-medium text-base-content/75 transition-colors hover:bg-base-content/10 hover:text-base-content">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M15 12H3" />
                        </svg>
                        <span class="hidden lg:inline">Login</span>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
            <ThemeSelector />
        </div>
    </div>
</header>

@code {
    // When rendered into a boosted-nav fragment, the topbar is sent as an out-of-band
    // swap so its active state refreshes without re-rendering the persistent shell.
    // outerMorph keeps the mutation minimal (preserves focus); transition:false keeps
    // the topbar out of the view transition so it doesn't crossfade. Default (false)
    // is the normal in-shell render.
    [Parameter] public bool OutOfBand { get; set; }
}
