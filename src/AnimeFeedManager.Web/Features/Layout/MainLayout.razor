@inherits LayoutComponentBase
@using AnimeFeedManager.Web.Htmx
@inject IHttpContextAccessor HttpContextAccessor

@{
    // Three render shapes keyed on request type (Model B — htmx 4 persistent shell):
    //  • HxPartial — a targeted component swap; emit the page fragment bare.
    //  • HxFull    — a boosted page navigation; emit the #main-content wrapper (the boost
    //                target/select) plus the topbar as an OOB swap so its active state
    //                refreshes. The persistent shell (drawer / footer) is NOT re-emitted.
    //  • Html      — a normal browser navigation; emit the whole shell.
    var requestType = HttpContextAccessor.GetHtmxRequestType();
    const string MainClass = "flex-1 px-4 pb-12 pt-5 md:px-8";
}

@if (requestType is HxPartial)
{
    @Body
}
else if (requestType is HxFull)
{
    <main id="main-content" class="@MainClass">
        @Body
    </main>
    <NavBar OutOfBand="true" />
}
else
{
    @* Full shell for a normal browser navigation. #mobile-drawer is the toggle for the
       full-screen MobileDrawer menu and is marked `peer` so `peer-checked:` drives the
       menu's open state (the menu is a following sibling). The topbar hamburger / the
       menu's close button are <label for="mobile-drawer"> controls.

       On a boosted nav only #main-content + the OOB topbar are re-emitted, so this whole
       wrapper persists — the `on htmx:after:swap` handler stays live and unchecks the
       toggle once the swapped-in page has landed, fading the menu out to reveal it. *@
    <div class="flex min-h-screen flex-col"
         _="on htmx:after:swap set #mobile-drawer's checked to false">
        <input id="mobile-drawer" type="checkbox" class="peer sr-only" aria-label="Toggle menu" />

        <NavBar />
        <main id="main-content" class="@MainClass">
            @Body
        </main>
        <StatusBar />

        <MobileDrawer />
    </div>
}
