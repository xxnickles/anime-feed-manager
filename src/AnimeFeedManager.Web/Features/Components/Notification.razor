@* Reusable toast notification, rendered into #toast-panel via an out-of-band swap
   (see NotificationOob.razor / Notifications.cs). Lean: auto-dismiss after CloseTime,
   manual dismiss, fade-out. Styled as a brutalist base-100 card (matches the trigger
   cards) so contrast holds in every theme — the type is signalled by the icon colour,
   not a tinted background (the themes don't define the daisyUI -content tokens that a
   coloured alert would need). Hyperscript is bound via the @Script C# string because
   Razor can't parse a multi-line _= attribute that contains <…> selector markup. *@

<div role="alert"
     class="flex w-[min(92vw,24rem)] items-start gap-2.5 rounded-none border-[3px] border-base-content bg-base-100 px-3.5 py-3 text-base-content shadow-brutal transition-opacity duration-300"
     data-close-seconds="@((int)CloseTime.TotalSeconds)"
     _="@Script">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2" class="mt-0.5 h-5 w-5 shrink-0 @IconColor">
        @Icon
    </svg>
    <div class="flex-1">
        <h3 class="font-display text-sm font-black">@Title</h3>
        @if (Message is not null)
        {
            <div class="mt-0.5 text-xs text-base-content/80">@Message</div>
        }
    </div>
    <button type="button" data-dismiss aria-label="Dismiss"
            class="-mr-1 -mt-1 shrink-0 rounded p-1 text-base-content/50 transition-colors hover:bg-base-content/10 hover:text-base-content">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" />
        </svg>
    </button>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public RenderFragment? Message { get; set; }
    [Parameter] public ToastType Type { get; set; } = ToastType.Info;
    [Parameter] public TimeSpan CloseTime { get; set; } = TimeSpan.FromSeconds(6);

    // Toast lifecycle (auto-dismiss countdown + manual dismiss + fade-out) lives in
    // Notification.razor.hs, compiled to the `Script` const and bound _="@Script".
    // CloseTime is passed to it via the data-close-seconds attribute.

    private string IconColor => Type switch
    {
        ToastType.Success => "text-success",
        ToastType.Error => "text-error",
        ToastType.Warning => "text-warning",
        ToastType.Info => "text-info",
        _ => "text-info"
    };

    private MarkupString Icon => (MarkupString)(Type switch
    {
        ToastType.Success => """<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />""",
        ToastType.Error => """<path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />""",
        ToastType.Warning => """<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />""",
        _ => """<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />"""
    });
}
