@*
    Filter state:
    - data-filter on the root element drives CSS show/hide rules.
    - Updated on filterChanged event dispatched by GridFilter.
*@
<div @attributes="AdditionalAttributes"
     id="main-grid"
     data-filter=""
     _="on filterChanged(filter) from body set @@data-filter to filter">
    <section class="grid grid-cols-[repeat(auto-fit,minmax(300px,0.75fr))] lg:grid-cols-[repeat(auto-fit,minmax(300px,400px))] justify-center auto-rows-min gap-10 px-2 md:px-10 py-2 md:py-4">
        <div class="col-span-full justify-self-end -mb-6">
            <GridFilter IsAuthenticated="IsAuthenticated" FilterCounters="FilterCounters" />
        </div>
        @ChildContent
    </section>
</div>


@code {
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = @<span>No content here!</span>;

    [Parameter, EditorRequired] public FilterCounters FilterCounters { get; set; }

    [Parameter] public bool IsAuthenticated { get; set; }


}
