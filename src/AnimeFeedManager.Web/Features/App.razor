@using AnimeFeedManager.Web.Htmx
@inject IWebHostEnvironment Env
@inject IHttpContextAccessor HttpContextAccessor

@{
    // HTMX 4: a "partial" request targets a specific element, so return only the fragment.
    // Everything else — normal navigation and "full" (boosted / body-level) HTMX requests —
    // gets the complete document so HTMX can swap the body and merge the head.
    var isPartial = HttpContextAccessor.GetHtmxRequestType() is HxPartial;
}

@if (isPartial)
{
    <Routes />
}
else
{
    <!DOCTYPE html>
    <html lang="en" class="scroll-pt-16">

    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content="Track and manage your anime season library." />
        <meta name="theme-color" content="#1a1a2e" />

        <meta name="htmx-config" content='{"globalViewTransitions":true}' />

        <!-- Web fonts (cdnfonts) -->
        <link rel="preconnect" href="https://fonts.cdnfonts.com" crossorigin />
        <link href="https://fonts.cdnfonts.com/css/inter" rel="stylesheet" />
        <link href="https://fonts.cdnfonts.com/css/archivo" rel="stylesheet" />
        <link href="https://fonts.cdnfonts.com/css/sf-mono" rel="stylesheet" />

        <base href="/" />

        <script>
            // Re-apply the user's stored theme before first paint. Absent => no data-theme
            // attribute, so daisyui's paper-light (--default) / paper-dark (--prefersdark)
            // follow the system preference. Kept in sync by ThemeSelector.razor.
            (function () {
                const theme = localStorage.getItem('user-theme');
                if (theme) {
                    document.documentElement.setAttribute('data-theme', theme);
                }
            })();
        </script>

        <link rel="stylesheet" href="@Assets["app.css"]" />
        <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />

        <ImportMap />
        <HeadOutlet />
    </head>

    <body class="bg-base-200 min-h-screen min-w-[380px]">

        <Routes />

        @if (Env.IsDevelopment())
        {
            <script defer src="@Assets["lib/htmx/dist/htmx.js"]"></script>
            <script defer src="@Assets["lib/htmx/dist/ext/hx-sse.js"]"></script>
            <script defer src="@Assets["lib/hyperscript/dist/_hyperscript.js"]"></script>
            <script defer src="@Assets["lib/hyperscript/dist/ext/component.js"]"></script>
        }
        else
        {
            <script defer src="@Assets["lib/htmx/dist/htmx.min.js"]"></script>
            <script defer src="@Assets["lib/htmx/dist/ext/hx-sse.min.js"]"></script>
            <script defer src="@Assets["lib/hyperscript/dist/_hyperscript.min.js"]"></script>
            <script defer src="@Assets["lib/hyperscript/dist/ext/component.min.js"]"></script>
        }

    </body>

    </html>
}
