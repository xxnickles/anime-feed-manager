@page "/"
@using AnimeFeedManager.Features.Library.Seasons
@using AnimeFeedManager.Features.Library.Seasons.Storage
@using AnimeFeedManager.Infrastructure.Cosmos
@using AnimeFeedManager.Shared.Results
@using AnimeFeedManager.Shared.Results.Errors
@using AnimeFeedManager.Shared.Results.Static
@using AnimeFeedManager.Shared.Types
@using AnimeFeedManager.Web.Features.Catalog
@inject ICosmosContainerFactory Factory
@inject ILogger<Home> Logger

@* Landing page: the latest imported season's grid. Resolves the latest season (NotFoundError when
   nothing is imported yet → a friendly "import a season" empty state), then hands it to SeasonGrid. *@

<AppPageTitle Title="@(_season?.ToString())" />

@if (_season is { } season)
{
    <SeasonGrid Season="season" />
}
else if (_error is NotFoundError)
{
    <WarnBanner Title="No seasons imported yet"
                Description="Import a season from the admin page to start building your library."
                ActionHref="/admin" ActionLabel="Go to admin" />
}
else
{
    <WarnBanner Title="Couldn't load the latest season"
                Description="Something went wrong reaching the library. Refresh to try again." />
}

@code {
    private SeriesSeason? _season;
    private DomainError? _error;

    protected override async Task OnInitializedAsync() =>
        await Factory.LatestSeasonResolverHandler()(CancellationToken.None)
            .Match(
                season => _season = season,
                error =>
                {
                    _error = error;
                    if (error is not NotFoundError) // benign "nothing imported" isn't worth an error log
                        error.LogAction()(Logger);
                });
}
