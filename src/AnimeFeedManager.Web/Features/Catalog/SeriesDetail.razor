@page "/series/{Season}/{MalId:int}"
@using AnimeFeedManager.Features.Library.Catalog
@using AnimeFeedManager.Features.Library.Entities
@using AnimeFeedManager.Features.Library.Catalog.Storage
@using Azure.Storage.Blobs
@inject ICosmosContainerFactory Factory
@inject BlobServiceClient BlobServiceClient
@inject ILogger<SeriesDetail> Logger

@* One series' detail page (e.g. /series/2026-spring/52991). The season segment is required because a
   MalId is unique only within its season partition (see SeriesByIdLoader). The slug is parsed the same
   way as SeasonPage — a sync gate that branches the view — then the series is point-read server-side.

   Layout ported from Styles/detail.css to Tailwind + daisyUI. Custom CSS retained only where Tailwind
   can't express it: `.detail-hero-bg` (blur+scale poster backdrop) and `.status-pin`/`.pin-dot` (glass
   backdrop, shared with SeriesCard). Everything else is utilities. *@

<AppPageTitle Title="@PageTitle"/>

@switch (_context)
{
    case InvalidSeason:
        <WarnBanner Title="Invalid season"
                    Description="@($"'{Season}' isn't a valid season — use a format like 2026-spring.")"/>
        break;
    case SeriesNotFound:
        <WarnBanner Title="Series not found"
                    Description="@($"No series with id {MalId} exists in {Season}.")"
                    ActionHref="@($"/{Season}")" ActionLabel="Back to season"/>
        break;
    case ProcessFailed:
        <WarnBanner Title="Couldn't load this series"
                    Description="Something went wrong fetching the series. Refresh to try again."/>
        break;
    case SeriesDetailAvailable {Series: { } series}:
    {
        <article class="relative -mx-4 -mt-5 overflow-hidden md:-mx-8">
            @if (PosterUrl(series) is { } backdrop)
            {
                <div class="detail-hero-bg" style="background-image:url('@backdrop')"></div>
            }
            <div class="absolute inset-0 bg-linear-to-b from-base-100/70 to-base-200"></div>

            <div class="relative px-4 pt-6 pb-10 md:px-8 md:pt-8">
                <NavLink href="@($"/{Season}")"
                         class="mb-6 inline-flex items-center gap-1.5 rounded-md bg-base-content/[0.06] px-2.5 py-1.5 text-xs font-semibold text-base-content transition-colors hover:bg-base-content/[0.12]">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" class="h-3.5 w-3.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
                    </svg>
                    Back to @Season
                </NavLink>

                <div class="mx-auto grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-[240px_1fr] md:gap-8">
                    @* ── Poster column ── *@
                    <div class="flex flex-col gap-3">
                        <div class="relative w-full max-w-60">
                            @if (AiringPin(series) is { } pin)
                            {
                                <div class="status-pin @pin.Color"><span class="pin-dot"></span>@pin.Label</div>
                            }
                            @if (PosterUrl(series) is { } poster)
                            {
                                <img src="@poster" alt="@SeriesTitle(series)"
                                     class="aspect-[2/3] w-full rounded-box object-cover shadow-brutal"/>
                            }
                            else
                            {
                                <div class="flex aspect-[2/3] w-full items-center justify-center rounded-box bg-base-content/5 p-4 text-center font-display text-sm font-bold text-base-content/40">
                                    @SeriesTitle(series)
                                </div>
                            }
                        </div>

                        @if (ExternalLinks(series).Any())
                        {
                            <div class="flex w-full max-w-60 flex-col">
                                <span class="@Eyebrow mb-1">Links</span>
                                @foreach (var (label, href) in ExternalLinks(series))
                                {
                                    <a href="@href" target="_blank" rel="noopener noreferrer" hx-boost="false"
                                       class="flex items-center justify-between rounded-md px-2 py-1.5 text-sm transition-colors hover:bg-base-content/[0.06]">
                                        <span>@label</span>
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 opacity-50" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                                        </svg>
                                    </a>
                                }
                            </div>
                        }
                    </div>

                    @* ── Content column ── *@
                    <div class="min-w-0">
                        <span class="@Eyebrow">@series.TypeLabel</span>
                        <h1 class="mt-1.5 font-display text-4xl font-extrabold leading-[1.05] tracking-[-0.025em] text-pretty md:text-5xl">@SeriesTitle(series)</h1>

                        @if (Romaji(series) is { } romaji || series.Titles.Japanese is { } jp)
                        {
                            <p class="mt-2 text-sm text-base-content/65">
                                @if (Romaji(series) is { } r)
                                {
                                    <span>@r</span>
                                }
                                @if (series.Titles.Japanese is { } j)
                                {
                                    @if (Romaji(series) is not null)
                                    {
                                        <span class="px-1.5 opacity-40">·</span>
                                    }
                                    <span class="font-ja text-base">@j</span>
                                }
                            </p>
                        }

                        @if (series.Genres.Length > 0)
                        {
                            <div class="mt-3.5 flex flex-wrap gap-1.5">
                                @foreach (var (genre, index) in series.Genres.Select((g, i) => (g, i)))
                                {
                                    <span class="badge badge-soft @(index == 0 ? "badge-primary" : "")">@genre</span>
                                }
                            </div>
                        }

                        @* ── Key stats ── *@
                        <dl class="mt-5 grid grid-cols-[repeat(auto-fit,minmax(150px,1fr))] gap-px overflow-hidden rounded-xl border border-base-content/10 bg-base-content/[0.08]">
                            <div class="bg-base-100 px-3.5 py-2.5">
                                <dt class="@Eyebrow">Score</dt>
                                @if (series.Score is { } score)
                                {
                                    <dd class="mt-1.5 flex items-center gap-2">
                                        <span class="font-display text-lg font-bold">@score.ToString("0.0")</span>
                                        <span class="h-[5px] w-[60px] overflow-hidden rounded-full bg-base-content/[0.12]">
                                            <span class="block h-full rounded-full bg-linear-to-r from-primary to-secondary" style="width:@ScorePercent(score)%"></span>
                                        </span>
                                    </dd>
                                }
                                else
                                {
                                    <dd class="mt-1.5 font-display text-lg font-bold text-base-content/40">—</dd>
                                }
                            </div>
                            <div class="bg-base-100 px-3.5 py-2.5">
                                <dt class="@Eyebrow">Format</dt>
                                <dd class="mt-1.5 font-display text-lg font-bold">@(series.FormatSummary ?? "—")</dd>
                            </div>
                            <div class="bg-base-100 px-3.5 py-2.5">
                                <dt class="@Eyebrow">Status</dt>
                                <dd class="mt-1.5 font-display text-lg font-bold">@series.Status.ToDisplayString()</dd>
                            </div>
                            <div class="bg-base-100 px-3.5 py-2.5">
                                <dt class="@Eyebrow">Season</dt>
                                <dd class="mt-1.5 font-display text-lg font-bold">@series.SeriesSeason</dd>
                            </div>
                        </dl>

                        @if (series.Synopsis is { } synopsis)
                        {
                            <section class="mt-6">
                                <h2 class="@Eyebrow mb-2">Synopsis</h2>
                                <p class="max-w-[56ch] leading-relaxed text-pretty text-base-content/90">@synopsis</p>
                            </section>
                        }

                        <section class="mt-6">
                            <h2 class="@Eyebrow mb-2">Details</h2>
                            <dl class="flex flex-col">
                                @foreach (var (label, value) in DetailRows(series))
                                {
                                    <div class="flex justify-between gap-4 border-t border-base-content/[0.07] py-1.5 text-sm first:border-t-0">
                                        <dt class="text-base-content/60">@label</dt>
                                        <dd class="text-right font-semibold">@value</dd>
                                    </div>
                                }
                            </dl>
                        </section>
                    </div>
                </div>
            </div>
        </article>
        break;
    }
}

@code {
    [Parameter] public string Season { get; set; } = string.Empty;
    [Parameter] public int MalId { get; set; }

    // Shared eyebrow-label styling (uppercase micro-caps) used across the page's section headers.
    private const string Eyebrow = "font-display text-[0.62rem] font-bold uppercase tracking-[0.14em] text-base-content/55";

    private SeriesDetailContext _context = new ProcessFailed();
    private string _imageBase = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _imageBase = $"{BlobServiceClient.Uri.AbsoluteUri.TrimEnd('/')}/";
        _context = await Season.ParseAsSeriesSeason()
            .Bind(parsed => CatalogQueries.GetSeasonalSeries(Factory.SeriesByIdLoaderHandler(), parsed, MalId, CancellationToken.None)
                .Map(series => (Series: series, Season: parsed)))
            .FlushLogs(Logger)
            .MatchToValue<(Series Series, SeriesSeason Season), SeriesDetailContext>(
                data =>new SeriesDetailAvailable(data.Series, data.Season),
                error => error switch
                {
                    DomainValidationErrors =>  new InvalidSeason(),
                    NotFoundError => new SeriesNotFound(),
                    _ =>  new ProcessFailed()
                });
    }

    private string PageTitle => _context is SeriesDetailAvailable {Series: { } series} ? SeriesTitle(series) : "Series";

    private static string SeriesTitle(Series series) =>
        string.IsNullOrWhiteSpace(series.Titles.English) ? series.Titles.Default : series.Titles.English!;

    // Canonical (romaji) title, shown as a subtitle only when it differs from the displayed primary.
    private static string? Romaji(Series series) =>
        string.Equals(series.Titles.Default, SeriesTitle(series), StringComparison.Ordinal) ? null : series.Titles.Default;

    private string? PosterUrl(Series series) =>
        series.CoverImageUrl is { } path ? _imageBase + path : null;

    // Airing-status pin (NOT user status). Only live/upcoming earn a pin; finished/unknown show none.
    private static (string Label, string Color)? AiringPin(Series series) => series.Status.ToString() switch
    {
        SeriesStatus.CurrentlyAiringValue => ("Airing", "text-success"),
        SeriesStatus.NotYetAiredValue => ("Upcoming", "text-info"),
        _ => null
    };

    private static int ScorePercent(double score) => (int)Math.Round(Math.Clamp(score, 0, 10) * 10);

    private static IEnumerable<(string Label, string Href)> ExternalLinks(Series series)
    {
        if (!string.IsNullOrWhiteSpace(series.MalUrl)) yield return ("MyAnimeList", series.MalUrl!);
        if (!string.IsNullOrWhiteSpace(series.TrailerUrl)) yield return ("Trailer", series.TrailerUrl!);
    }

    private static IEnumerable<(string Label, string Value)> DetailRows(Series series)
    {
        yield return ("Type", series.TypeLabel);
        if (!string.IsNullOrWhiteSpace(series.Source)) yield return ("Source", series.Source!);
        if (series.Studios.Length > 0) yield return ("Studios", string.Join(", ", series.Studios));
        if (AiredRange(series) is { } aired) yield return ("Aired", aired);
        if (series.Schedule is { } b) yield return ("Broadcast", $"{b.Day} {b.Time} ({b.Timezone})");
    }

    private static string? AiredRange(Series series)
    {
        if (series.AiredFrom is not { } from) return null;
        var fromStr = from.ToString("MMM d, yyyy");
        return series.AiredTo is { } to ? $"{fromStr} – {to:MMM d, yyyy}" : fromStr;
    }
}
