{
  "name": "anime-feed-manager-v5-client",
  "version": "5.0.0",
  "scripts": {
    "build:js": "node build-js.mjs",
    "watch:js": "node build-js.mjs --watch",
    "build:css": "npx @tailwindcss/cli -i ./Styles/app.css -o ./wwwroot/app.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./Styles/app.css -o ./wwwroot/app.css --watch",
    "build": "npm run build:css && npm run build:js",
    "watch": "concurrently \"npm run watch:css\" \"npm run watch:js\"",
    "update:libs": "ncu -u && npm install",
    "update:libman": "node libman-update.js"
  },
  "devDependencies": {
    "@swc/core": "^1.15.41",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "daisyui": "^5.5.23",
    "glob": "^13.0.6",
    "npm-check-updates": "^22.2.3",
    "tailwindcss": "^4.3.1"
  }
}
