{
  "version": "1.0",
  "defaultProvider": "jsdelivr",
  "libraries": [
    {
      "library": "htmx.org@4.0.0-beta5",
      "destination": "wwwroot/lib/htmx/",
      "files": [
        "dist/htmx.js",
        "dist/htmx.min.js",
        "dist/ext/hx-sse.js",
        "dist/ext/hx-sse.min.js"
      ]
    },
    {
      "library": "hyperscript.org@0.9.93",
      "destination": "wwwroot/lib/hyperscript/",
      "files": [
        "dist/_hyperscript.js",
        "dist/_hyperscript.min.js",
        "dist/ext/component.js",
        "dist/ext/component.min.js",
        "dist/ext/eventsource.js",
        "dist/ext/eventsource.min.js"
      ]
    },
    {
      "library": "@passwordlessdev/passwordless-client@1.2.4",
      "destination": "wwwroot/lib/passwordless-client",
      "files": [
        "dist/esm/passwordless.mjs",
        "dist/esm/passwordless.min.mjs"
      ]
    }
  ]
}
