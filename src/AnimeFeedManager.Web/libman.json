{
  "version": "1.0",
  "defaultProvider": "unpkg",
  "libraries": [
    {
      "provider": "unpkg",
      "library": "htmx.org@4.0.0-beta4",
      "destination": "wwwroot/lib/htmx/",
      "files": [
        "dist/htmx.js",
        "dist/htmx.min.js",
        "dist/ext/hx-sse.js",
        "dist/ext/hx-sse.min.js"
      ]
    },
    {
      "provider": "unpkg",
      "library": "hyperscript.org@0.9.91",
      "destination": "wwwroot/lib/hyperscript/",
      "files": [
        "dist/_hyperscript.js",
        "dist/_hyperscript.min.js",
        "dist/ext/component.js",
        "dist/ext/component.min.js",
        "dist/ext/eventsource.js",
        "dist/ext/eventsource.min.js"
      ]
    }
  ]
}
